{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_script_v1.json",
  "title": "MSM Trainer Script",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "script_id",
    "session_id",
    "orchestrator_plan_id",
    "script_author",
    "created_at",
    "concept",
    "card_id",
    "checkpoint",
    "session_mode",
    "intended_stage",
    "intended_failure_targets",
    "trainer_contract",
    "items"
  ],
  "properties": {
    "schema_version": {"const": "msm_script_v1"},
    "script_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "orchestrator_plan_id": {"type": "string", "minLength": 1},
    "script_author": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "concept": {"type": "string", "minLength": 1},
    "card_id": {"type": "string", "minLength": 1},
    "checkpoint": {"type": "string", "minLength": 1},
    "session_mode": {
      "enum": [
        "scripted_trainer_session",
        "probe_session",
        "repair_replay_session",
        "contrast_session",
        "protected_anchor_session"
      ]
    },
    "intended_stage": {"type": "string", "minLength": 1},
    "intended_failure_targets": {
      "type": "array",
      "items": {"type": "string"}
    },
    "trainer_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "send_user_prompt",
        "record_original_answer",
        "send_teacher_correction",
        "record_after_correction_answer",
        "do_not_grade",
        "do_not_modify_items"
      ],
      "properties": {
        "send_user_prompt": {"const": true},
        "record_original_answer": {"const": true},
        "send_teacher_correction": {"type": "boolean"},
        "record_after_correction_answer": {"type": "boolean"},
        "do_not_grade": {"const": true},
        "do_not_modify_items": {"const": true}
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item_id",
          "stage",
          "user_prompt",
          "teacher_correction",
          "ask_after_correction",
          "expected_original",
          "expected_after_correction",
          "target_failure_modes",
          "training_answer_max_bytes"
        ],
        "properties": {
          "item_id": {"type": "string", "minLength": 1},
          "stage": {"type": "string", "minLength": 1},
          "user_prompt": {"type": "string", "minLength": 1},
          "teacher_correction": {"type": ["string", "null"]},
          "ask_after_correction": {"type": "boolean"},
          "expected_original": {
            "type": "object",
            "additionalProperties": false,
            "required": ["acceptable", "forbidden"],
            "properties": {
              "acceptable": {
                "type": "array",
                "items": {"type": "string"}
              },
              "forbidden": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          },
          "expected_after_correction": {
            "type": "object",
            "additionalProperties": false,
            "required": ["acceptable", "forbidden"],
            "properties": {
              "acceptable": {
                "type": "array",
                "items": {"type": "string"}
              },
              "forbidden": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          },
          "required_hits": {
            "type": "array",
            "items": {"type": "string"}
          },
          "forbidden_hits": {
            "type": "array",
            "items": {"type": "string"}
          },
          "target_failure_modes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "training_answer_max_bytes": {"type": "integer", "minimum": 1},
          "notes": {"type": ["string", "null"]}
        }
      }
    }
  }
}
