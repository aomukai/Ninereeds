{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_cold_start_phase_v1.json",
  "title": "MSM Cold-Start Phase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase_id",
    "phase_index",
    "name",
    "goal",
    "entry_requirements",
    "frontload",
    "evaluation",
    "success_gates",
    "failure_interpretation",
    "allowed_next_phases"
  ],
  "properties": {
    "schema_version": {"const": "msm_cold_start_phase_v1"},
    "phase_id": {"type": "string", "minLength": 1},
    "phase_index": {"type": "integer", "minimum": 0},
    "name": {"type": "string", "minLength": 1},
    "goal": {"type": "string", "minLength": 1},
    "entry_requirements": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "frontload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_data_shapes",
        "forbidden_data_shapes",
        "dose_policy",
        "checkpoint_policy"
      ],
      "properties": {
        "allowed_data_shapes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "forbidden_data_shapes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "dose_policy": {"type": "string", "minLength": 1},
        "checkpoint_policy": {"type": "string", "minLength": 1}
      }
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "probe_families",
        "metrics",
        "non_goals"
      ],
      "properties": {
        "probe_families": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "metrics": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "non_goals": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "success_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["gate_id", "metric", "threshold", "comparison"],
        "properties": {
          "gate_id": {"type": "string", "minLength": 1},
          "metric": {"type": "string", "minLength": 1},
          "threshold": {"type": ["number", "integer", "string", "boolean"]},
          "comparison": {"enum": ["gte", "lte", "eq", "manual_review"]}
        }
      }
    },
    "failure_interpretation": {"type": "string", "minLength": 1},
    "allowed_next_phases": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "notes": {"type": ["string", "null"]}
  }
}
