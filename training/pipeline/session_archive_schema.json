{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_session_archive_v1.json",
  "title": "MSM Session Archive",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "entries"
  ],
  "properties": {
    "schema_version": {"const": "msm_session_archive_v1"},
    "updated_at": {"type": "string", "minLength": 1},
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "session_id",
          "concept",
          "card_id",
          "created_at",
          "checkpoint_before",
          "session_mode",
          "executor_id",
          "strategy",
          "script_fingerprint",
          "scores",
          "successful_axes",
          "weak_axes",
          "failure_modes",
          "artifacts"
        ],
        "properties": {
          "session_id": {"type": "string", "minLength": 1},
          "concept": {"type": "string", "minLength": 1},
          "card_id": {"type": "string", "minLength": 1},
          "created_at": {"type": "string", "minLength": 1},
          "checkpoint_before": {"type": "string", "minLength": 1},
          "session_mode": {
            "enum": [
              "scripted_trainer_session",
              "probe_session",
              "repair_replay_session",
              "contrast_session",
              "protected_anchor_session"
            ]
          },
          "executor_id": {"type": "string", "minLength": 1},
          "strategy": {"type": "string", "minLength": 1},
          "script_fingerprint": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "algorithm",
              "structural_hash",
              "prompt_hash",
              "question_type_sequence",
              "contrast_pairs"
            ],
            "properties": {
              "algorithm": {"const": "msm_script_fingerprint_v1"},
              "structural_hash": {"type": "string", "minLength": 1},
              "prompt_hash": {"type": "string", "minLength": 1},
              "question_type_sequence": {
                "type": "array",
                "items": {"type": "string"}
              },
              "contrast_pairs": {
                "type": "array",
                "items": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "items": {"type": "string"}
                }
              }
            }
          },
          "scores": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "original_correct_rate",
              "after_correction_correct_rate",
              "on_topic_rate",
              "malformed_rate",
              "session_passed"
            ],
            "properties": {
              "original_correct_rate": {"type": "number", "minimum": 0, "maximum": 1},
              "after_correction_correct_rate": {"type": "number", "minimum": 0, "maximum": 1},
              "on_topic_rate": {"type": "number", "minimum": 0, "maximum": 1},
              "malformed_rate": {"type": "number", "minimum": 0, "maximum": 1},
              "session_passed": {"type": "boolean"}
            }
          },
          "successful_axes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "weak_axes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "failure_modes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "artifacts": {
            "type": "object",
            "additionalProperties": false,
            "required": ["report_card", "report_md", "script"],
            "properties": {
              "report_card": {"type": "string", "minLength": 1},
              "report_md": {"type": "string", "minLength": 1},
              "script": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    }
  }
}
