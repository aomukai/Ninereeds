{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_active_campaign_policy_v1.json",
  "title": "MSM Active Campaign Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "created_at",
    "author",
    "objective",
    "auto_advance_allowed",
    "max_auto_advance_words",
    "max_retries_per_word",
    "checkpoint_policy",
    "primary_metrics",
    "secondary_metrics",
    "deepseek_allowed_actions",
    "escalate_if"
  ],
  "properties": {
    "schema_version": {"const": "msm_active_campaign_policy_v1"},
    "campaign_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "author": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "auto_advance_allowed": {"type": "boolean"},
    "max_auto_advance_words": {"type": "integer", "minimum": 0},
    "max_retries_per_word": {"type": "integer", "minimum": 0},
    "checkpoint_policy": {"type": "string", "minLength": 1},
    "primary_metrics": {
      "type": "object",
      "additionalProperties": {"type": ["number", "integer", "string", "boolean", "null"]}
    },
    "secondary_metrics": {
      "type": "object",
      "additionalProperties": {"type": ["number", "integer", "string", "boolean", "null"]}
    },
    "deepseek_allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "PASS_AUTONEXT",
          "PASS_BUT_BUFFER",
          "RETRY_SAME_WORD",
          "ESCALATE_CODEX",
          "ESCALATE_HUMAN"
        ]
      },
      "uniqueItems": true
    },
    "escalate_if": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
