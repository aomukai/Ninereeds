{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_session_report_v1.json",
  "title": "MSM Session Report Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "concept",
    "card_id",
    "checkpoint_before",
    "checkpoint_after",
    "session_mode",
    "script",
    "counts",
    "scores",
    "failure_modes",
    "successful_axes",
    "weak_axes",
    "protected_anchor_status",
    "recommended_extraction",
    "executor_recommendation",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "msm_session_report_v1"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "concept": {
      "type": "string",
      "minLength": 1
    },
    "card_id": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_before": {
      "type": "string",
      "minLength": 1
    },
    "checkpoint_after": {
      "type": ["string", "null"]
    },
    "session_mode": {
      "enum": [
        "scripted_trainer_session",
        "probe_session",
        "repair_replay_session",
        "contrast_session",
        "protected_anchor_session"
      ]
    },
    "script": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_id",
        "script_author",
        "script_mode",
        "orchestrator_plan_id",
        "intended_stage",
        "intended_failure_targets"
      ],
      "properties": {
        "script_id": {"type": "string", "minLength": 1},
        "script_author": {"type": "string", "minLength": 1},
        "script_mode": {"const": "fixed"},
        "orchestrator_plan_id": {"type": "string", "minLength": 1},
        "intended_stage": {"type": "string", "minLength": 1},
        "intended_failure_targets": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_items",
        "ninereeds_original_answers",
        "ninereeds_after_correction_answers",
        "original_correct",
        "original_wrong_on_topic",
        "original_wrong_off_topic",
        "after_correction_correct",
        "after_correction_wrong_on_topic",
        "after_correction_wrong_off_topic",
        "malformed",
        "repetition_collapse",
        "empty_or_near_empty"
      ],
      "properties": {
        "script_items": {"type": "integer", "minimum": 0},
        "ninereeds_original_answers": {"type": "integer", "minimum": 0},
        "ninereeds_after_correction_answers": {"type": "integer", "minimum": 0},
        "original_correct": {"type": "integer", "minimum": 0},
        "original_wrong_on_topic": {"type": "integer", "minimum": 0},
        "original_wrong_off_topic": {"type": "integer", "minimum": 0},
        "after_correction_correct": {"type": "integer", "minimum": 0},
        "after_correction_wrong_on_topic": {"type": "integer", "minimum": 0},
        "after_correction_wrong_off_topic": {"type": "integer", "minimum": 0},
        "malformed": {"type": "integer", "minimum": 0},
        "repetition_collapse": {"type": "integer", "minimum": 0},
        "empty_or_near_empty": {"type": "integer", "minimum": 0}
      }
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_correct_rate",
        "after_correction_correct_rate",
        "on_topic_rate",
        "malformed_rate",
        "session_passed",
        "executor_may_auto_advance",
        "requires_orchestrator"
      ],
      "properties": {
        "original_correct_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "after_correction_correct_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "on_topic_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "malformed_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "session_passed": {"type": "boolean"},
        "executor_may_auto_advance": {"type": "boolean"},
        "requires_orchestrator": {"type": "boolean"}
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "severity", "item_ids", "example", "interpretation"],
        "properties": {
          "type": {"type": "string", "minLength": 1},
          "severity": {"enum": ["low", "medium", "high", "critical"]},
          "item_ids": {
            "type": "array",
            "items": {"type": "string"}
          },
          "example": {"type": "string"},
          "interpretation": {"type": "string"}
        }
      }
    },
    "successful_axes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "weak_axes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "protected_anchor_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tested", "passed", "failures"],
      "properties": {
        "tested": {"type": "boolean"},
        "passed": {"type": ["boolean", "null"]},
        "failures": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "recommended_extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proposed_training_turns",
        "rejected_turns",
        "extraction_file",
        "do_not_train_raw_log"
      ],
      "properties": {
        "proposed_training_turns": {"type": "integer", "minimum": 0},
        "rejected_turns": {"type": "integer", "minimum": 0},
        "extraction_file": {"type": ["string", "null"]},
        "do_not_train_raw_log": {"const": true}
      }
    },
    "executor_recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommendation_type",
        "suggested_next_session_mode",
        "suggested_focus",
        "requires_orchestrator_decision",
        "requires_human_attention"
      ],
      "properties": {
        "recommendation_type": {
          "enum": [
            "accept",
            "continue_same_word",
            "continue_next_word",
            "repair_replay",
            "probe",
            "brain_scan",
            "micro_update",
            "escalate",
            "reject"
          ]
        },
        "suggested_next_session_mode": {"type": ["string", "null"]},
        "suggested_focus": {
          "type": "array",
          "items": {"type": "string"}
        },
        "requires_orchestrator_decision": {"type": "boolean"},
        "requires_human_attention": {"type": "boolean"}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_log",
        "script",
        "report_md",
        "turn_grades",
        "proposed_training",
        "failed_turns"
      ],
      "properties": {
        "raw_log": {"type": "string"},
        "script": {"type": "string"},
        "report_md": {"type": "string"},
        "turn_grades": {"type": "string"},
        "proposed_training": {"type": ["string", "null"]},
        "failed_turns": {"type": "string"}
      }
    }
  }
}
