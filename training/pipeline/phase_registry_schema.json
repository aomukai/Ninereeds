{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_phase_registry_v1.json",
  "title": "MSM Phase Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "regime",
    "current_phase_id",
    "phase_sequence",
    "phases",
    "transition_history"
  ],
  "properties": {
    "schema_version": {"const": "msm_phase_registry_v1"},
    "updated_at": {"type": "string", "minLength": 1},
    "regime": {"const": "cold_start_msm"},
    "current_phase_id": {"type": "string", "minLength": 1},
    "phase_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "phases": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "phase_id",
          "definition",
          "status",
          "gate_status",
          "started_at",
          "completed_at",
          "latest_eval",
          "notes"
        ],
        "properties": {
          "phase_id": {"type": "string", "minLength": 1},
          "definition": {"type": "string", "minLength": 1},
          "status": {
            "enum": [
              "pending",
              "active",
              "blocked",
              "complete",
              "skipped",
              "retired"
            ]
          },
          "gate_status": {
            "enum": [
              "not_started",
              "not_met",
              "met",
              "manual_review",
              "blocked"
            ]
          },
          "started_at": {"type": ["string", "null"]},
          "completed_at": {"type": ["string", "null"]},
          "latest_eval": {"type": ["string", "null"]},
          "notes": {"type": ["string", "null"]}
        }
      }
    },
    "transition_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "created_at",
          "from_phase_id",
          "to_phase_id",
          "reason",
          "approved_by"
        ],
        "properties": {
          "created_at": {"type": "string", "minLength": 1},
          "from_phase_id": {"type": ["string", "null"]},
          "to_phase_id": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "approved_by": {"type": "string", "minLength": 1}
        }
      }
    },
    "notes": {"type": ["string", "null"]}
  }
}
