{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_update_manifest_v1.json",
  "title": "MSM Update Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "update_id",
    "created_at",
    "parent_checkpoint",
    "output_checkpoint",
    "source_sessions",
    "approved_training_files",
    "approved_turn_count",
    "approval",
    "update_backend",
    "target_axes",
    "protected_anchors_required"
  ],
  "properties": {
    "schema_version": {"const": "msm_update_manifest_v1"},
    "update_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "parent_checkpoint": {"type": "string", "minLength": 1},
    "output_checkpoint": {"type": "string", "minLength": 1},
    "source_sessions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "approved_training_files": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "approved_turn_count": {"type": "integer", "minimum": 1},
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "orchestrator_approved",
        "approved_by",
        "approval_reason",
        "human_approved"
      ],
      "properties": {
        "orchestrator_approved": {"const": true},
        "approved_by": {"type": "string", "minLength": 1},
        "approval_reason": {"type": "string", "minLength": 1},
        "human_approved": {"type": "boolean"}
      }
    },
    "update_backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "command", "learning_rate", "max_steps", "notes"],
      "properties": {
        "name": {"const": "buffered_micro_update"},
        "command": {"type": "string", "minLength": 1},
        "learning_rate": {"type": "number", "exclusiveMinimum": 0},
        "max_steps": {"type": "integer", "minimum": 1},
        "notes": {"type": "string"}
      }
    },
    "target_axes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "protected_anchors_required": {"type": "boolean"}
  }
}
