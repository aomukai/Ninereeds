{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_auto_advance_state_v1.json",
  "title": "MSM Auto-Advance State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "updated_at",
    "current_word",
    "current_card_id",
    "last_session_id",
    "last_action",
    "auto_advanced_count",
    "retry_counts",
    "next_word",
    "requires_codex",
    "reason"
  ],
  "properties": {
    "schema_version": {"const": "msm_auto_advance_state_v1"},
    "campaign_id": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "minLength": 1},
    "current_word": {"type": ["string", "null"]},
    "current_card_id": {"type": ["string", "null"]},
    "last_session_id": {"type": ["string", "null"]},
    "last_action": {
      "enum": [
        "PASS_AUTONEXT",
        "PASS_BUT_BUFFER",
        "RETRY_SAME_WORD",
        "ESCALATE_CODEX",
        "ESCALATE_HUMAN",
        "NONE"
      ]
    },
    "auto_advanced_count": {"type": "integer", "minimum": 0},
    "retry_counts": {
      "type": "object",
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "next_word": {"type": ["string", "null"]},
    "requires_codex": {"type": "boolean"},
    "reason": {"type": "string", "minLength": 1}
  }
}
