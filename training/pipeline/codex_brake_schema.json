{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_codex_brake_v1.json",
  "title": "MSM Codex Brake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "updated_at",
    "source",
    "action",
    "reason",
    "reset_at",
    "five_hour_percent_left",
    "weekly_percent_left",
    "highest_percent_used"
  ],
  "properties": {
    "updated_at": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "action": {
      "enum": [
        "continue",
        "conservative_mode",
        "finish_current_only",
        "pause_until_reset",
        "blocked_unknown_reset"
      ]
    },
    "reason": {"type": "string", "minLength": 1},
    "reset_at": {"type": ["string", "null"]},
    "five_hour_percent_left": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "weekly_percent_left": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "highest_percent_used": {"type": ["integer", "null"], "minimum": 0, "maximum": 100}
  }
}
