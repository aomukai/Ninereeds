{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_training_turn_v1.json",
  "title": "MSM Training Turn",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "concept",
    "card_id",
    "turn_id",
    "prompt",
    "training_answer",
    "source",
    "target_failure",
    "deepseek_validated",
    "orchestrator_approved"
  ],
  "properties": {
    "schema_version": {"const": "msm_training_turn_v1"},
    "session_id": {"type": "string", "minLength": 1},
    "concept": {"type": "string", "minLength": 1},
    "card_id": {"type": "string", "minLength": 1},
    "turn_id": {"type": "string", "minLength": 1},
    "prompt": {"type": "string", "minLength": 1},
    "training_answer": {"type": "string", "minLength": 1},
    "source": {
      "enum": [
        "deepseek_proposed_correction",
        "deepseek_expected_answer",
        "orchestrator_repair_line",
        "protected_anchor_replay"
      ]
    },
    "target_failure": {"type": ["string", "null"]},
    "deepseek_validated": {"type": "boolean"},
    "orchestrator_approved": {"type": "boolean"}
  }
}
