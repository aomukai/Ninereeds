{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_orchestrator_config_v1.json",
  "title": "MSM Orchestrator Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "checkpoint_policy",
    "thresholds",
    "buffer_policy",
    "scheduler_policy",
    "executor_selection",
    "executor_prompt_context",
    "deduplication_policy",
    "sentinel_contract",
    "codex_status_schema",
    "codex_brake_schema",
    "script_schema",
    "raw_chat_line_schema",
    "phase_registry_schema",
    "phase_block_report_schema",
    "concept_state_schema",
    "session_archive_schema",
    "active_campaign_policy_schema",
    "word_queue_schema",
    "auto_advance_state_schema",
    "update_manifest_schema",
    "update_candidate_eval_schema"
  ],
  "properties": {
    "schema_version": {"const": "msm_orchestrator_config_v1"},
    "checkpoint_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_parent",
        "current_parent",
        "accepted_checkpoint",
        "historical_checkpoints_are_parents"
      ],
      "properties": {
        "initial_parent": {"const": "scratch"},
        "current_parent": {"type": "string", "minLength": 1},
        "accepted_checkpoint": {"type": ["string", "null"]},
        "historical_checkpoints_are_parents": {"const": false}
      }
    },
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_malformed_rate",
        "max_repetition_collapse",
        "max_empty_or_near_empty_rate",
        "min_correct_items_to_continue",
        "max_off_topic_answers_to_continue"
      ],
      "properties": {
        "max_malformed_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "max_repetition_collapse": {"type": "integer", "minimum": 0},
        "max_empty_or_near_empty_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "min_correct_items_to_continue": {"type": "integer", "minimum": 0},
        "max_off_topic_answers_to_continue": {"type": "integer", "minimum": 0}
      }
    },
    "buffer_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_proposed_turns_for_update",
        "min_approved_turns_for_update",
        "max_sessions_per_buffer",
        "allow_single_session_repair_update"
      ],
      "properties": {
        "min_proposed_turns_for_update": {"type": "integer", "minimum": 1},
        "min_approved_turns_for_update": {"type": "integer", "minimum": 1},
        "max_sessions_per_buffer": {"type": "integer", "minimum": 1},
        "allow_single_session_repair_update": {"type": "boolean"}
      }
    },
    "scheduler_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "learnability_weight",
        "severity_weight",
        "underexplored_weight",
        "retry_penalty_weight",
        "protected_anchor_weight"
      ],
      "properties": {
        "learnability_weight": {"type": "number"},
        "severity_weight": {"type": "number"},
        "underexplored_weight": {"type": "number"},
        "retry_penalty_weight": {"type": "number"},
        "protected_anchor_weight": {"type": "number"}
      }
    },
    "executor_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selection_mode",
        "default_executor",
        "available_executors"
      ],
      "properties": {
        "selection_mode": {"enum": ["fixed"]},
        "default_executor": {"type": "string", "minLength": 1},
        "available_executors": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "executor_prompt_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inject_meta_scratchpad",
        "meta_scratchpad_path"
      ],
      "properties": {
        "inject_meta_scratchpad": {"type": "boolean"},
        "meta_scratchpad_path": {"type": "string", "minLength": 1}
      }
    },
    "deduplication_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "script_fingerprint_algorithm",
        "reject_exact_structural_duplicates",
        "warn_prompt_jaccard_above",
        "allow_repetition_with_policy_reason"
      ],
      "properties": {
        "script_fingerprint_algorithm": {"const": "msm_script_fingerprint_v1"},
        "reject_exact_structural_duplicates": {"type": "boolean"},
        "warn_prompt_jaccard_above": {"type": "number", "minimum": 0, "maximum": 1},
        "allow_repetition_with_policy_reason": {"type": "boolean"}
      }
    },
    "sentinel_contract": {"type": "string", "minLength": 1},
    "codex_status_schema": {"type": "string", "minLength": 1},
    "codex_brake_schema": {"type": "string", "minLength": 1},
    "script_schema": {"type": "string", "minLength": 1},
    "raw_chat_line_schema": {"type": "string", "minLength": 1},
    "phase_registry_schema": {"type": "string", "minLength": 1},
    "phase_block_report_schema": {"type": "string", "minLength": 1},
    "concept_state_schema": {"type": "string", "minLength": 1},
    "session_archive_schema": {"type": "string", "minLength": 1},
    "active_campaign_policy_schema": {"type": "string", "minLength": 1},
    "word_queue_schema": {"type": "string", "minLength": 1},
    "auto_advance_state_schema": {"type": "string", "minLength": 1},
    "update_manifest_schema": {"type": "string", "minLength": 1},
    "update_candidate_eval_schema": {"type": "string", "minLength": 1}
  }
}
