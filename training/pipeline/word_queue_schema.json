{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_word_queue_v1.json",
  "title": "MSM Word Queue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "queue_created_at",
    "current_index",
    "items"
  ],
  "properties": {
    "schema_version": {"const": "msm_word_queue_v1"},
    "campaign_id": {"type": "string", "minLength": 1},
    "queue_created_at": {"type": "string", "minLength": 1},
    "current_index": {"type": "integer", "minimum": 0},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["word", "card_id", "status"],
        "properties": {
          "word": {"type": "string", "minLength": 1},
          "card_id": {"type": "string", "minLength": 1},
          "status": {"enum": ["pending", "running", "passed", "retrying", "failed", "escalated", "skipped"]},
          "session_id": {"type": ["string", "null"]},
          "notes": {"type": ["string", "null"]}
        }
      }
    }
  }
}
