{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_concept_state_v1.json",
  "title": "MSM Concept State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "updated_at",
    "cards"
  ],
  "properties": {
    "schema_version": {"const": "msm_concept_state_v1"},
    "updated_at": {"type": "string", "minLength": 1},
    "cards": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "concept",
          "card_id",
          "box",
          "answer_level",
          "attempts",
          "successes",
          "failures",
          "last_strategy",
          "last_session_id",
          "successful_axes",
          "weak_axes",
          "failure_modes",
          "axes",
          "strategy_stats"
        ],
        "properties": {
          "concept": {"type": "string", "minLength": 1},
          "card_id": {"type": "string", "minLength": 1},
          "box": {
            "enum": [
              "box_0_new",
              "box_1_failed",
              "box_2_passed_once",
              "box_3_stable",
              "box_4_anchor",
              "leech"
            ]
          },
          "answer_level": {"type": "integer", "minimum": 0, "maximum": 6},
          "attempts": {"type": "integer", "minimum": 0},
          "successes": {"type": "integer", "minimum": 0},
          "failures": {"type": "integer", "minimum": 0},
          "last_strategy": {"type": ["string", "null"]},
          "last_session_id": {"type": ["string", "null"]},
          "successful_axes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "weak_axes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "failure_modes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "axes": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "attempts",
                "original_successes",
                "post_correction_successes",
                "failures",
                "off_topic",
                "malformed",
                "last_status",
                "last_strategy",
                "last_session_id"
              ],
              "properties": {
                "attempts": {"type": "integer", "minimum": 0},
                "original_successes": {"type": "integer", "minimum": 0},
                "post_correction_successes": {"type": "integer", "minimum": 0},
                "failures": {"type": "integer", "minimum": 0},
                "off_topic": {"type": "integer", "minimum": 0},
                "malformed": {"type": "integer", "minimum": 0},
                "last_status": {
                  "enum": [
                    "correct",
                    "wrong_on_topic",
                    "wrong_off_topic",
                    "ungradable",
                    "not_tested"
                  ]
                },
                "last_strategy": {"type": ["string", "null"]},
                "last_session_id": {"type": ["string", "null"]}
              }
            }
          },
          "strategy_stats": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "additionalProperties": false,
              "required": ["attempts", "successes", "failures", "children_count"],
              "properties": {
                "attempts": {"type": "integer", "minimum": 0},
                "successes": {"type": "integer", "minimum": 0},
                "failures": {"type": "integer", "minimum": 0},
                "children_count": {"type": "integer", "minimum": 0}
              }
            }
          },
          "notes": {"type": ["string", "null"]}
        }
      }
    }
  }
}
