{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_phase_block_report_v1.json",
  "title": "MSM Phase Block Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "phase_id",
    "block_id",
    "created_at",
    "status",
    "checkpoint_before",
    "checkpoint_after",
    "frontload_examples",
    "train_command",
    "probe_command",
    "metrics",
    "gate_status",
    "local_recommendation",
    "artifacts"
  ],
  "properties": {
    "schema_version": {"const": "msm_phase_block_report_v1"},
    "phase_id": {"type": "string", "minLength": 1},
    "block_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "minLength": 1},
    "status": {"enum": ["planned", "trained", "probed", "failed"]},
    "checkpoint_before": {"type": "string", "minLength": 1},
    "checkpoint_after": {"type": ["string", "null"]},
    "frontload_examples": {"type": "integer", "minimum": 0},
    "train_command": {
      "type": "array",
      "items": {"type": "string"}
    },
    "probe_command": {
      "type": ["array", "null"],
      "items": {"type": "string"}
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {"type": ["number", "integer", "string", "boolean", "null"]}
    },
    "gate_status": {"enum": ["not_evaluated", "not_met", "met", "manual_review", "blocked"]},
    "local_recommendation": {
      "enum": [
        "run_next_block_same_phase",
        "phase_gate_review",
        "escalate_orchestrator",
        "blocked"
      ]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frontload_jsonl",
        "probe_jsonl",
        "probe_results_jsonl",
        "train_stdout",
        "report_json"
      ],
      "properties": {
        "frontload_jsonl": {"type": "string", "minLength": 1},
        "probe_jsonl": {"type": ["string", "null"]},
        "probe_results_jsonl": {"type": ["string", "null"]},
        "train_stdout": {"type": ["string", "null"]},
        "report_json": {"type": "string", "minLength": 1}
      }
    },
    "notes": {"type": ["string", "null"]}
  }
}
