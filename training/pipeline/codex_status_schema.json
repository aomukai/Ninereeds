{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_codex_status_v1.json",
  "title": "MSM Codex Status",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "updated_at",
    "source",
    "parse_ok",
    "five_hour_percent_left",
    "five_hour_resets",
    "weekly_percent_left",
    "weekly_resets",
    "five_hour_percent_used",
    "weekly_percent_used",
    "highest_percent_used",
    "last_hour_delta_used",
    "projected_exhaustion"
  ],
  "properties": {
    "updated_at": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "parse_ok": {"type": "boolean"},
    "five_hour_percent_left": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "five_hour_resets": {"type": ["string", "null"]},
    "weekly_percent_left": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "weekly_resets": {"type": ["string", "null"]},
    "five_hour_percent_used": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "weekly_percent_used": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "highest_percent_used": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
    "last_hour_delta_used": {"type": ["integer", "null"], "minimum": 0},
    "projected_exhaustion": {"enum": ["safe", "warning", "danger", "unknown"]}
  }
}
