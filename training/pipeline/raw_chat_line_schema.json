{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_raw_chat_line_v1.json",
  "title": "MSM Raw Chat JSONL Line",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "script_id",
    "item_id",
    "sequence_index",
    "event_type",
    "speaker",
    "text",
    "created_at"
  ],
  "properties": {
    "schema_version": {"const": "msm_raw_chat_line_v1"},
    "session_id": {"type": "string", "minLength": 1},
    "script_id": {"type": "string", "minLength": 1},
    "item_id": {"type": "string", "minLength": 1},
    "sequence_index": {"type": "integer", "minimum": 0},
    "event_type": {
      "enum": [
        "user_prompt",
        "ninereeds_original_answer",
        "teacher_correction",
        "ninereeds_after_correction_answer",
        "execution_error"
      ]
    },
    "speaker": {
      "enum": [
        "user",
        "ninereeds",
        "teacher",
        "trainer"
      ]
    },
    "text": {"type": "string"},
    "created_at": {"type": "string", "minLength": 1},
    "latency_ms": {"type": ["number", "null"], "minimum": 0},
    "checkpoint": {"type": ["string", "null"]},
    "inference": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "temperature": {"type": ["number", "null"]},
        "top_k": {"type": ["integer", "null"], "minimum": 1},
        "max_new_tokens": {"type": ["integer", "null"], "minimum": 1},
        "device": {"type": ["string", "null"]}
      }
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["type", "message"],
      "properties": {
        "type": {"type": "string", "minLength": 1},
        "message": {"type": "string", "minLength": 1},
        "retryable": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"event_type": {"const": "user_prompt"}}
      },
      "then": {
        "properties": {"speaker": {"const": "user"}}
      }
    },
    {
      "if": {
        "properties": {"event_type": {"const": "teacher_correction"}}
      },
      "then": {
        "properties": {"speaker": {"const": "teacher"}}
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "ninereeds_original_answer",
              "ninereeds_after_correction_answer"
            ]
          }
        }
      },
      "then": {
        "properties": {"speaker": {"const": "ninereeds"}}
      }
    },
    {
      "if": {
        "properties": {"event_type": {"const": "execution_error"}}
      },
      "then": {
        "properties": {"speaker": {"const": "trainer"}}
      }
    }
  ]
}
