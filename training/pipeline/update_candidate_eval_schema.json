{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninereeds.local/schemas/msm_update_candidate_eval_v1.json",
  "title": "MSM Update Candidate Eval",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "update_id",
    "candidate_checkpoint",
    "parent_checkpoint",
    "target_checks",
    "protected_anchor_checks",
    "quality_checks",
    "decision"
  ],
  "properties": {
    "schema_version": {"const": "msm_update_candidate_eval_v1"},
    "update_id": {"type": "string", "minLength": 1},
    "candidate_checkpoint": {"type": "string", "minLength": 1},
    "parent_checkpoint": {"type": "string", "minLength": 1},
    "target_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "summary", "report_cards"],
      "properties": {
        "passed": {"type": "boolean"},
        "summary": {"type": "string"},
        "report_cards": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "protected_anchor_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tested", "passed", "failures"],
      "properties": {
        "tested": {"type": "boolean"},
        "passed": {"type": "boolean"},
        "failures": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "quality_checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["malformed_rate_ok", "repetition_rate_ok", "script_deviation"],
      "properties": {
        "malformed_rate_ok": {"type": "boolean"},
        "repetition_rate_ok": {"type": "boolean"},
        "script_deviation": {"type": "boolean"}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason", "promoted_checkpoint"],
      "properties": {
        "status": {"enum": ["accepted", "rejected", "manual_review"]},
        "reason": {"type": "string", "minLength": 1},
        "promoted_checkpoint": {"type": ["string", "null"]}
      }
    }
  }
}
