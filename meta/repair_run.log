const fs = require('fs');
const damage = fs.readFileSync('training_data/phases/damage_map.txt', 'utf-8');
const progress = fs.readFileSync('training_data/phases/repair_progress.txt', 'utf-8');

const filePattern = /phase_\d+(?:_\d+)?\.md/gi;
const allFiles = [];
const seen = new Set();
let match;
while ((match = filePattern.exec(damage)) !== null) {
    if (!seen.has(match[0])) {
        seen.add(match[0]);
        allFiles.push(match[0]);
    }
}

const doneFiles = new Set();
for (const line of progress.split('\n')) {
    const t = line.trim();
    if (t.startsWith('DONE ')) {
        const names = t.substring(5).match(/phase_\d+(?:_\d+)?\.md/gi);
        if (names) for (const n of names) doneFiles.add(n);
    }
}

const unknownPrefixes = ['phase_2_32', 'phase_2_33', 'phase_2_34'];
function isUnknown(f) { return unknownPrefixes.some(p => f.startsWith(p)); }

const totalRemaining = allFiles.filter(f => !doneFiles.has(f)).length;
const remainingNonUnknown = allFiles.filter(f => !doneFiles.has(f) && !isUnknown(f)).length;
const remainingUnknown = allFiles.filter(f => !doneFiles.has(f) && isUnknown(f)).length;

console.log('Files remaining (total):', totalRemaining);
console.log('Files remaining (non-UNKNOWN):', remainingNonUnknown);
console.log('Files remaining (UNKNOWN skipped):', remainingUnknown);
"

