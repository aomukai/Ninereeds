            done.add(line[5:].strip())

# Read damage_map
with open('training_data/phases/damage_map.txt') as f:
    content = f.read()

# Parse filenames - handle concatenated .md files (edge case)
# Split by newlines first
lines = content.split('\n')

all_files = []
for line in lines:
    line = line.strip()
    if not line:
        continue
    # Remove line numbers like '1: ', '2: ', etc.
    line = re.sub(r'^\d+:\s*', '', line)
    
    # Handle edge case: two filenames concatenated without newline
    # e.g. phase_1_1067.mdphase_1_511.md -> phase_1_1067.md, phase_1_511.md
    # Find all .md filenames in the line
    filenames = re.findall(r'(phase_\d+_\d+\.md)', line)
    if filenames:
        for fn in filenames:
            all_files.append(fn)
    else:
        # Try phase with just _N format
        filenames = re.findall(r'(phase_\d+_\d+\.md)', line)
        if not filenames:
            # Try broader pattern
            filenames = re.findall(r'(phase_\d+_\d+\.md)', line)
        if filenames:
            for fn in filenames:
                all_files.append(fn)

# Also try more patterns
