const fs = require('fs');
const damage = fs.readFileSync('training_data/phases/damage_map.txt','utf8');
const progress = fs.readFileSync('training_data/phases/repair_progress.txt','utf8');

// Extract done filenames from progress
const doneSet = new Set();
const pLines = progress.split('\n');
for (let line of pLines) {
    const matches = line.match(/phase_\d+_\d+\.md/g);
    if (matches) matches.forEach(m => doneSet.add(m));
}

// Extract filenames from damage_map preserving order, unique
const seen = new Set();
const ordered = [];
const dLines = damage.split('\n');
for (let line of dLines) {
    const matches = line.match(/phase_\d+_\d+\.md/g);
    if (matches) {
        for (let m of matches) {
            if (!seen.has(m)) {
                seen.add(m);
                ordered.push(m);
            }
        }
    }
}

// Find first 25 not in doneSet
const pending = ordered.filter(f => !doneSet.has(f));
console.log('Total unique in damage_map:', ordered.length);
console.log('Already done:', doneSet.size);
console.log('Pending:', pending.length);
console.log('First 25 pending:');
pending.slice(0,25).forEach((f,i) => console.log((i+1)+': '+f));
"

