import re

# Read progress file - handle concatenated entries
with open('repair_progress.txt') as f:
    content = f.read()

done = set()
# Find all DONE entries, handling concatenated cases
for m in re.finditer(r'DONE\s+(phase_\d+_\d+\.md)', content):
    done.add(m.group(1))
# Also handle concatenated without space like DONE phase_6_218.mdDONE phase_6_221.md
for m in re.finditer(r'DONE\s+(phase_\d+_\d+\.md)(?:DONE|$)', content):
    done.add(m.group(1))
# More thorough: find all .md after DONE
for m in re.finditer(r'DONE\s*(\S+?\.md)', content):
    done.add(m.group(1))

print(f'Total done entries: {len(done)}')

# Read damage map - extract filenames preserving order
with open('damage_map.txt') as f:
    lines = f.readlines()

seen_first = set()
ordered_files = []
file_issues_map = {}

for line in lines:
    line = line.strip()
    if not line:
        continue
    # Find all .md filenames in this line (handle concatenated)
    # Split by .md boundary
    remaining = line
    while remaining:
        m = re.match(r'(phase_\d+_\d+\.md)\s*(.*)', remaining)
        if not m:
            break
        fname = m.group(1)
        rest = m.group(2)
        if fname not in seen_first:
            seen_first.add(fname)
            ordered_files.append(fname)
            file_issues_map[fname] = []
        if rest:
            file_issues_map[fname].append(rest)
        # Continue with rest for concatenated
        remaining = rest.strip()

# Find first 25 NOT in done, skipping UNKNOWN files
first_25 = []
skipped_unknown = []
for fname in ordered_files:
    if len(first_25) >= 25:
        break
    if fname in done:
        continue
    # Check if it's an UNKNOWN placeholder file (phase_2_32X.md - phase_2_34X.md with UNKNOWN)
    if fname.startswith('phase_2_32') or fname.startswith('phase_2_33'):
        skipped_unknown.append(fname)
        continue
    first_25.append(fname)

print(f'\nFirst 25 files not in progress (skipping UNKNOWN):')
for f in first_25:
    issues = file_issues_map.get(f, [])
    print(f'{f}: {\" \".join(issues[:2])}')

print(f'\nSkipped UNKNOWN: {skipped_unknown}')
print(f'\nTotal files processed: {len(first_25)}')
