import re, os

# Read repair_progress
done = set()
with open('training_data/phases/repair_progress.txt', 'r') as f:
    for line in f:
        m = re.search(r'DONE\s+(phase_\S+\.md)', line)
        if m:
            done.add(m.group(1))

# Read damage_map
with open('training_data/phases/damage_map.txt', 'r') as f:
    content = f.read()

lines = content.strip().split('\n')
all_entries = []
for line in lines:
    line = line.strip()
    if not line or line.startswith('---'):
        continue
    line_clean = re.sub(r'^\d+:\s*', '', line)
    filenames = re.findall(r'(phase_\d+_\d+\.md)', line_clean)
    if not filenames:
        filenames = re.findall(r'(phase_\d+\.md)', line_clean)
    for fn in filenames:
        all_entries.append((fn, line_clean))

# Collect unique, skip UNKNOWN and done
seen = []
issues_for = {}
for fn, full_line in all_entries:
    if fn in done:
        continue
    if fn in seen:
        continue
    # Determine phase from filename
    phase_match = re.match(r'phase_(\d+)', fn)
    if not phase_match:
        continue
    phase_num = phase_match.group(1)
    filepath = f'training_data/phases/phase_{phase_num}/{fn}'
    # Check if file has UNKNOWN
    has_unknown = False
    if os.path.exists(filepath):
        with open(filepath, 'r') as f:
            content = f.read()
            if 'UNKNOWN' in content:
                has_unknown = True
    if has_unknown:
        continue
    seen.append(fn)
    issues_for[fn] = full_line
    if len(seen) >= 25:
        break

print('First 25 non-UNKNOWN, non-DONE files:')
for fn in seen:
    print(fn + ': ' + issues_for[fn][:150])
"

