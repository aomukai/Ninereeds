]

print('=== COMPREHENSIVE CHECK ===')
all_ok = True
for fname in files_to_check:
    path = f'training_data/phases/phase_1/{fname}'
    with open(path) as f:
        lines = f.readlines()
    content = ''.join(lines)
    
    errs = []
    
    # Line count
    if len(lines) != 35:
        errs.append(f'LINE_COUNT: {len(lines)}')
    
    # Trailing blank line
    if len(lines) > 0 and lines[-1].strip() == '':
        errs.append('TRAILING_BLANK')
    
    # Check structure blocks
    # Block boundaries: 1-8, 9 blank, 10-17, 18 blank, 19-26, 27 blank, 28-35
    block_template = {1:'user', 2:'Ninereeds', 10:'user', 11:'Ninereeds', 19:'user', 20:'Ninereeds', 28:'user', 29:'Ninereeds'}
    for ln, expected in block_template.items():
        if ln <= len(lines):
            if not lines[ln-1].startswith(f'[{expected}]'):
                errs.append(f'L{ln}: expected [{expected}] tag')
    
    # Question templates for phase 1
    question_map = {1: 'what does', 10: 'where can you find', 19: 'what does', 28: 'what does'}
    for ln, expected_start in question_map.items():
        if ln <= len(lines):
            qline = lines[ln-1].lower()
            if not qline.startswith(f'[{expected_start}') and not qline.startswith(f'[user]{expected_start}'):
                errs.append(f'L{ln} question does not begin with \"{expected_start}\"')
    
    # Check Q4 gives template
    q4 = lines[27].lower().strip() if 27 < len(lines) else ''
    if 'give' not in q4:
        errs.append(f'L28 Q4 missing \"give\": {lines[27].strip()}')
    
    # Summary lines use 'and'  
    for lineno in [8, 17, 26, 35]:
        if lineno <= len(lines):
            line = lines[lineno-1]
            if line.strip() and not line.startswith('['):
                if ' and ' not in line:
                    errs.append(f'L{lineno} summary missing \"and\"')
    
    # Negation check
    for i, line in enumerate(lines, 1):
        if line.strip() and not line.startswith('[user]'):
            lower = line.lower()
            for nw in [' not ', ' no ', ' cannot ', ' never ', ' without ']:
                if nw in lower:
                    errs.append(f'L{i} negation: {line.strip()}')
    
    # Pronoun check  
    for i, line in enumerate(lines, 1):
        if line.strip() and not line.startswith('[user]'):
            lower = line.lower()
            # Skip false positives like 'other'
            for p in [' it ', ' its ', ' they ', ' their ', ' he ', ' she ']:
                if p in lower:
                    errs.append(f'L{i} pronoun \"{p.strip()}\"')
    
    if errs:
        all_ok = False
        print(f'=== {fname} ===')
        for e in errs:
            print(f'  {e}')

if all_ok:
    print('ALL 25 FILES COMPREHENSIVELY PASSED')
else:
    print('\\nSome files have issues.')
