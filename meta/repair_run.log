with open('training_data/phases/repair_progress.txt') as f:
    done = set()
    for line in f:
        line = line.strip()
        if line.startswith('DONE '):
            done.add(line[5:].strip())

with open('training_data/phases/damage_map.txt') as f:
    content = f.read()

lines = content.split('\n')
all_files = []
for line in lines:
    line = line.strip()
    if not line:
        continue
    line = re.sub(r'^\d+:\s*', '', line)
    filenames = re.findall(r'phase_\d+_\d+\.md', line)
    for fn in filenames:
        all_files.append(fn)

seen = set()
unique_files = []
for fn in all_files:
    if fn not in seen:
        seen.add(fn)
        unique_files.append(fn)

todo = [f for f in unique_files if f not in done]

# Known UNKNOWN phase_2 files
unknown_ph2 = set()
for i in range(323, 342):
    unknown_ph2.add(f'phase_2_{i}.md')

filtered = [f for f in todo if f not in unknown_ph2]

print(f'First 25 non-UNKNOWN:')
for i, f in enumerate(filtered[:25], 1):
    print(f'{i}. {f}')
print()
print(f'Next 10:')
for i, f in enumerate(filtered[25:35], 1):
    print(f'{i+25}. {f}')
"

