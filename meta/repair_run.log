const fs = require('fs');
const damage = fs.readFileSync('training_data/phases/damage_map.txt', 'utf-8');
const progress = fs.readFileSync('training_data/phases/repair_progress.txt', 'utf-8');

// Extract all .md filenames from damage map in order of appearance
const filePattern = /phase_\d+(?:_\d+)?\.md/gi;
const allFiles = [];
let match;
while ((match = filePattern.exec(damage)) !== null) {
    allFiles.push(match[0]);
}

// Get unique in order of first appearance
const seen = new Set();
const uniqueOrdered = [];
for (const f of allFiles) {
    if (!seen.has(f)) {
        seen.add(f);
        uniqueOrdered.push(f);
    }
}

// Extract done files
const doneFiles = new Set();
const progressLines = progress.split('\n');
for (const line of progressLines) {
    const trimmed = line.trim();
    if (trimmed.startsWith('DONE ')) {
        const names = trimmed.substring(5).match(/phase_\d+(?:_\d+)?\.md/gi);
        if (names) {
            for (const n of names) doneFiles.add(n);
        }
    }
}

// Is UNKNOWN - check these files
const unknownPrefixes = ['phase_2_32', 'phase_2_33', 'phase_2_34'];
function isUnknown(f) {
    for (const p of unknownPrefixes) {
        if (f.startsWith(p)) return true;
    }
    return false;
}

// Find remaining non-UNKNOWN files in order
const remaining = uniqueOrdered.filter(f => !doneFiles.has(f) && !isUnknown(f));
console.log('First 25 remaining non-UNKNOWN files:');
remaining.slice(0, 25).forEach((f, i) => console.log('  ' + (i+1) + '. ' + f));
console.log('Total remaining non-UNKNOWN:', remaining.length);

// Also tell us which UNKNOWN files were skipped
const skippedUnknown = uniqueOrdered.filter(f => !doneFiles.has(f) && isUnknown(f));
console.log('\\nSkipped UNKNOWN files:');
skippedUnknown.forEach(f => console.log('  ' + f));
