import re

# Read progress file
with open('repair_progress.txt') as f:
    content = f.read()

done = set()
for m in re.finditer(r'DONE\s*(\S+?\.md)', content):
    done.add(m.group(1))

print(f'Total done: {len(done)}')

# Read damage map - extract filenames preserving order
with open('damage_map.txt') as f:
    lines = f.readlines()

seen_first = set()
ordered_files = []

for line in lines:
    line = line.strip()
    if not line:
        continue
    remaining = line
    while remaining:
        m = re.match(r'(phase_\d+_\d+\.md)\s*(.*)', remaining)
        if not m:
            break
        fname = m.group(1)
        if fname not in seen_first:
            seen_first.add(fname)
            ordered_files.append(fname)
        remaining = m.group(2).strip()

# Find first 25 NOT in done, checking for UNKNOWN content
first_25 = []
skipped_unknown = []
idx = 0
while len(first_25) < 25 and idx < len(ordered_files):
    fname = ordered_files[idx]
    idx += 1
    if fname in done:
        continue
    
    # Check if UNKNOWN file (either phase_2_32X-33X, or we'll check content)
    # Read the file to check for UNKNOWN
    phase_match = re.match(r'phase_(\d+)_(\d+)\.md', fname)
    if phase_match:
        phase_num = phase_match.group(1)
        file_num = phase_match.group(2)
        filepath = f'phase_{phase_num}/phase_{phase_num}_{file_num}.md'
        try:
            with open(filepath) as f:
                content_check = f.read()
            if 'UNKNOWN' in content_check:
                skipped_unknown.append(fname)
                continue
            else:
                first_25.append(fname)
        except FileNotFoundError:
