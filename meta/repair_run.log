import re, os

# Read repair_progress
done = set()
with open('training_data/phases/repair_progress.txt', 'r') as f:
    for line in f:
        m = re.search(r'DONE\s+(phase_\S+\.md)', line)
        if m:
            done.add(m.group(1))

# Read damage_map
with open('training_data/phases/damage_map.txt', 'r') as f:
    content = f.read()

lines = content.strip().split('\n')
all_entries = []
for line_raw in lines:
    line = line_raw.strip()
    if not line or line.startswith('---'):
        continue
    line_clean = re.sub(r'^\d+:\s*', '', line)
    filenames = re.findall(r'(phase_\d+_\d+\.md)', line_clean)
    if not filenames:
        filenames = re.findall(r'(phase_\d+\.md)', line_clean)
    for fn in filenames:
        all_entries.append(fn)

# Count unique entries
unique_map = {}
for fn in all_entries:
    if fn not in unique_map:
        unique_map[fn] = 0
    unique_map[fn] += 1

total_unique = len(unique_map)
remaining = sum(1 for fn in unique_map if fn not in done)

print(f'Total unique files in damage_map: {total_unique}')
print(f'Files done (in repair_progress): {len(done)}')  
print(f'Files remaining in damage_map: {remaining}')
"

