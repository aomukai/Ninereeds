import re

# Read damage_map and extract all filenames
with open('training_data/phases/damage_map.txt', 'r') as f:
    damage_lines = f.readlines()

# Extract filenames - handle the edge case of concatenated files
damage_files = set()
for line in damage_lines:
    line = line.strip()
    # Find all .md filenames
    matches = re.findall(r'phase_\d+_\d+\.md', line)
    for m in matches:
        damage_files.add(m)
    # Also handle case like phase_6_218.mdDONE or phase_1_1067.mdphase_1_511.md
    # Look for patterns where a filename directly touches another filename
    parts = re.split(r'[^a-zA-Z0-9_.]', line)
    for part in parts:
        if re.match(r'^phase_\d+_\d+\.md$', part):
            damage_files.add(part)
    # Also try to find merged filenames
    # e.g., phase_1_1067.mdphase_1_511.md
    merged = re.findall(r'(phase_\d+_\d+\.md)(phase_\d+_\d+\.md)', line)
    for pair in merged:
        damage_files.add(pair[0])
        damage_files.add(pair[1])

print('Unique files in damage_map:', len(damage_files))
for f in sorted(list(damage_files))[:10]:
    print(f)
print('...')
