import re

# Read damage_map.txt
with open('training_data/phases/damage_map.txt', 'r') as f:
    damage_lines = f.read()

# Extract all filenames from damage_map, handling concatenated files
filenames = set()
for line in damage_lines.split('\n'):
    line = line.strip()
    if not line:
        continue
    # Remove line numbers at start
    line = re.sub(r'^\d+:\s*', '', line)
    # Extract filenames - any token ending in .md
    tokens = line.split()
    for token in tokens:
        # Handle concatenated case: phase_X_NNN.mdphase_Y_MMM.md
        matches = re.findall(r'(phase_\d+_\d+\.md)', token)
        for m in matches:
            filenames.add(m)

print(f'Total unique files in damage_map: {len(filenames)}')
print('---')

# Read repair_progress.txt
completed = set()
with open('training_data/phases/repair_progress.txt', 'r') as f:
    for line in f:
        line = line.strip()
