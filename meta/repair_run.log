    const trimmed = line.trim();
    if (trimmed.startsWith('DONE ')) {
        // Handle concatenated entries like DONE phase_6_218.mdDONE phase_6_221.md
        const names = trimmed.substring(5).match(/phase_\d+(?:_\d+)?\.md/gi);
        if (names) {
            for (const n of names) doneFiles.add(n);
