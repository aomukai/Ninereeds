const fs = require('fs');
const damageText = fs.readFileSync('training_data/phases/damage_map.txt', 'utf8');
const progressText = fs.readFileSync('training_data/phases/repair_progress.txt', 'utf8');

// Parse unique filenames from damage map
const doneFiles = new Set();
progressText.split('\n').forEach(line => {
  const m = line.match(/DONE\s+(phase_\d+_\d+\.md)/);
  if (m) doneFiles.add(m[1]);
});

// Extract all filenames from damage map
const allDamageFiles = new Map(); // filename -> array of issue lines
const lines = damageText.split('\n');
for (const line of lines) {
  if (!line.trim()) continue;
  // Handle concatenated filenames: phase_X_NNN.mdphase_Y_MMM.md
  const concatMatch = line.match(/(phase_\d+_\d+\.md)(phase_\d+_\d+\.md)/);
  if (concatMatch) {
    const f1 = concatMatch[1];
    const f2 = concatMatch[2];
    if (!allDamageFiles.has(f1)) allDamageFiles.set(f1, []);
    allDamageFiles.get(f1).push(line.trim());
    if (!allDamageFiles.has(f2)) allDamageFiles.set(f2, []);
    allDamageFiles.get(f2).push(line.trim());
    continue;
  }
  // Normal: filename is first token ending in .md
  const m = line.match(/(phase_\d+_\d+\.md)/);
  if (m) {
    const f = m[1];
    if (!allDamageFiles.has(f)) allDamageFiles.set(f, []);
    allDamageFiles.get(f).push(line.trim());
  }
}

// Filter to files NOT in done set
const remaining = [...allDamageFiles.keys()].filter(f => !doneFiles.has(f));
console.log('Total unique files in damage_map:', allDamageFiles.size);
console.log('Already done:', doneFiles.size);
console.log('Remaining to process:', remaining.length);
console.log('---');
console.log('First 25 remaining:');
remaining.slice(0, 25).forEach((f, i) => {
  const issues = allDamageFiles.get(f);
  console.log((i+1) + '. ' + f + ' -> ' + issues.join(' | '));
});
"

