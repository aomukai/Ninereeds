         'phase_3_411.md','phase_3_413.md','phase_3_417.md','phase_3_419.md','phase_3_462.md',
         'phase_3_464.md','phase_3_470.md','phase_3_477.md','phase_3_480.md','phase_3_511.md']

NEGATION_WORDS = [' not ', ' does not', ' do not', ' cannot ', ' never ', ' no ', ' without ', \" doesn't\", \" don't\", \" can't\", \" won't\", 'n\'t ']
PRONOUNS = [' it ', ' its ', ' they ', ' their ', ' him ', ' his ', ' her ', ' he ', ' she ']

all_ok = True
for fn in files:
    path = f'training_data/phases/phase_3/{fn}'
    with open(path) as f:
        lines = f.read().split('\n')
    
    issues = []
    
    # Check 35 lines
    if len(lines) != 35:
        issues.append(f'WRONG LINE COUNT: {len(lines)}')
    
    # Check trailing blank
    if lines[-1].strip() == '':
        issues.append('TRAILING BLANK LINE')
    
    # Check block counts
    user_tags = sum(1 for l in lines if l.startswith('[user]'))
    nr_tags = sum(1 for l in lines if l.startswith('[Ninereeds]'))
    if user_tags != 4 or nr_tags != 4:
        issues.append(f'BLOCK COUNT: user={user_tags}, nr={nr_tags}')
    
    # Check each Ninereeds block for 'This is' opener
    for i, l in enumerate(lines):
        if l.startswith('[Ninereeds]'):
            body = l[11:]
            if not body.startswith('This is '):
                issues.append(f'NR opener missing \"This is\" at line {i+1}: {body[:40]}')
    
    # Check body lines (lines after [Ninereeds] openers until blank)
    for i, l in enumerate(lines):
        if l and not l.startswith('[') and not l.startswith('This is '):
            # Check negation in body lines
            for neg in NEGATION_WORDS:
                if neg in l.lower():
                    issues.append(f'NEGATION at line {i+1}: \"{l.strip()[:50]}...\"')
                    break
            
            # Check pronouns
            for p in PRONOUNS:
                if p in (' ' + l.lower() + ' '):
                    issues.append(f'PRONOUN at line {i+1}: \"{l.strip()[:50]}...\"')
                    break
    
    # Check summary lines (lines 8, 17, 26, 35) have 'and'
    for sn in [8, 17, 26, 35]:
        if sn <= len(lines):
            l = lines[sn-1]
            if l.strip() and 'not a summary' in l.lower():
                continue
            # Only check if it's not a blank line and not a [user] tag
            if l.strip() and not l.startswith('['):
                if ' and ' not in l.lower():
                    issues.append(f'SUMMARY missing \"and\" at line {sn}: \"{l.strip()[:50]}...\"')
                if ' or ' in l.lower():
                    issues.append(f'SUMMARY has \"or\" at line {sn}: \"{l.strip()[:50]}...\"')
    
    if issues:
        all_ok = False
        print(f'{fn}: ISSUES')
        for iss in issues:
            print(f'  - {iss}')
        print()

if all_ok:
    print('ALL FILES PASS CHECK')
