import re, os

# Read repair_progress
done = set()
with open('training_data/phases/repair_progress.txt', 'r') as f:
    for line in f:
        m = re.search(r'DONE\s+(phase_\S+\.md)', line)
        if m:
            done.add(m.group(1))

# Count unique files in damage_map not done, not UNKNOWN
with open('training_data/phases/damage_map.txt', 'r') as f:
    content = f.read()

lines = content.strip().split('\n')
seen = []
unknown_skipped = []
for line_raw in lines:
    line = line_raw.strip()
    if not line or line.startswith('---'):
        continue
    line_clean = re.sub(r'^\d+:\s*', '', line)
    filenames = re.findall(r'(phase_\d+_\d+\.md)', line_clean)
    if not filenames:
        filenames = re.findall(r'(phase_\d+\.md)', line_clean)
    for fn in filenames:
        if fn in done or fn in seen:
            continue
        seen.append(fn)
        # Check for UNKNOWN
        phase_match = re.match(r'phase_(\d+)', fn)
        if phase_match:
            ph = phase_match.group(1)
            fpath = f'training_data/phases/phase_{ph}/{fn}'
            if os.path.exists(fpath):
                with open(fpath, 'r') as f:
                    fcontent = f.read()
                    if 'UNKNOWN' in fcontent:
                        unknown_skipped.append(fn)
                        continue

remaining_non_unknown = len([f for f in seen if f not in unknown_skipped and f not in done])
total_remaining = len(seen)

print(f'Total files remaining (unique, not done): {total_remaining}')
print(f'  - UNKNOWN (need human): {len(unknown_skipped)}')
print(f'  - Non-UNKNOWN remaining: {remaining_non_unknown}')
print(f'Files processed this run: 25')
print(f'Files skipped UNKNOWN: {len(unknown_skipped)}')
"

