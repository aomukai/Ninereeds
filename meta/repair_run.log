ordered = []
for line in lines:
    line = line.strip()
    if not line:
        continue
    remaining = line
    while remaining:
        m = re.match(r'(phase_\d+_\d+\.md)\s*(.*)', remaining)
        if not m:
            break
        fname = m.group(1)
        if fname not in seen_first:
            seen_first.add(fname)
            ordered.append(fname)
        remaining = m.group(2).strip()

remaining = [f for f in ordered if f not in done]
unknown = []
non_unknown = []
for f in remaining:
    phase_match = re.match(r'phase_(\d+)_(\d+)\.md', f)
    if phase_match:
        phase_num = phase_match.group(1)
        file_num = phase_match.group(2)
        import os
        filepath = f'phase_{phase_num}/phase_{phase_num}_{file_num}.md'
        if os.path.exists(filepath):
            with open(filepath) as fh:
                content_check = fh.read()
            if 'UNKNOWN' in content_check:
                unknown.append(f)
                continue
    non_unknown.append(f)

print(f'Total remaining in damage map: {len(remaining)}')
print(f'UNKNOWN placeholders: {unknown}')
print(f'Non-UNKNOWN remaining: {non_unknown[:10]}...')
print(f'Total non-UNKNOWN remaining: {len(non_unknown)}')
