import os

# Get all remaining not-done files from damage_map
with open('training_data/phases/repair_progress.txt', 'r') as f:
    done_lines = f.read().strip().split('\n')
done_files = set()
for line in done_lines:
    line = line.strip()
    if line.startswith('DONE '):
        done_files.add(line[5:].strip())
    elif line.startswith('DONE'):
        done_files.add(line[4:].strip())

import re
with open('training_data/phases/damage_map.txt', 'r') as f:
    map_text = f.read()

filenames_raw = re.findall(r'(phase_\d+_\d+\.md)', map_text)
filenames_raw = list(set(filenames_raw))
filenames_raw.sort()

not_done = [f for f in filenames_raw if f not in done_files]
print(f'Not done count: {len(not_done)}')

# Check each for UNKNOWN
viable = []
skipped_unknown = []
for f in not_done:
    parts = f.split('_')
    phase = f'phase_{parts[1]}'
    path = os.path.join('training_data', 'phases', phase, f)
    if os.path.exists(path):
        with open(path, 'r') as fh:
            content = fh.read()
        if 'UNKNOWN' in content:
            skipped_unknown.append(f)
        else:
            viable.append(f)
    else:
        skipped_unknown.append(f)

print(f'Viable (non-UNKNOWN): {len(viable)}')
print(f'Skipped (UNKNOWN/not found): {len(skipped_unknown)}')
print()
print('Viable files:')
for f in viable:
    print(f'  {f}')
